---
import { format } from "date-fns";
import MenuLines from "../components/MenuLines.astro";
import { APP_METADATA } from "../constants";
import { prose } from "../styles/prose.css";
import * as styles from "./ArticleLayout.css";
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;
---

<Layout title={title} description={description} ogType="article" publishedDate={date.toISOString()}>
  <article class={styles.article}>
    <MenuLines />
    <header class={styles.header}>
      <h1 class={styles.articleTitle}>{title}</h1>
      <div class={styles.metadata}>
        <span>{APP_METADATA.author}</span>
        <span> · </span>
        <time datetime={date.toISOString()}>{format(date, "yyyy.MM.dd")}</time>
        {tags.length > 0 && (
          <span> · {tags.join(", ")}</span>
        )}
      </div>
    </header>
    <div class={prose}><slot /></div>
    <footer class={styles.footer}><a class={styles.backLink} href="/">← Back to home</a></footer>
  </article>
</Layout>
