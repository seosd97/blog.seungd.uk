---
import "../styles/theme.css";
import "../styles/global.css";
import "../styles/editorial.css";
import { defaultTheme, themeStorageKey } from "../styles/theme.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "seosd의 블로그",
  description = "Astro와 Vanilla Extract로 시작하는 블로그 테마 베이스",
} = Astro.props;

const themeScript = `
(() => {
  const storageKey = ${JSON.stringify(themeStorageKey)};
  const root = document.documentElement;
  const savedTheme = localStorage.getItem(storageKey);
  const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  const nextTheme = savedTheme === 'light' || savedTheme === 'dark' ? savedTheme : systemTheme;

  root.dataset.theme = nextTheme;
})();
`;
---

<!doctype html>
<html lang="ko" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" href="/favicon.ico">
    <meta name="generator" content={Astro.generator}>
    <meta name="description" content={description}>
    <script is:inline set:html={themeScript}></script>
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 999;
    padding: 0.5rem 1rem;
    background: var(--bg-canvas);
    color: var(--text-strong);
    border: 1px solid var(--border-default);
    border-radius: 0.375rem;
    font-size: 0.875rem;
    text-decoration: none;
  }
  .skip-link:focus {
    top: 1rem;
  }
</style>
