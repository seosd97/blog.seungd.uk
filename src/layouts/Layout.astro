---
import '../styles/theme.css';
import '../styles/global.css';
import { defaultTheme, themeStorageKey } from '../styles/theme.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Quiet Archive',
  description = 'Astro와 Vanilla Extract로 시작하는 블로그 테마 베이스'
} = Astro.props;

const themeScript = `
(() => {
  const storageKey = ${JSON.stringify(themeStorageKey)};
  const root = document.documentElement;
  const savedTheme = localStorage.getItem(storageKey);
  const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  const nextTheme = savedTheme === 'light' || savedTheme === 'dark' ? savedTheme : systemTheme;

  root.dataset.theme = nextTheme;
})();
`;
---

<!doctype html>
<html lang="ko" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <script is:inline set:html={themeScript}></script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
