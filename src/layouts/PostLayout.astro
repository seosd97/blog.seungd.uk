---
import { metadata, postTitle, prose } from "../styles/editorial.css";
import * as styles from "../styles/post-layout.css";
import Layout from "./Layout.astro";
import { AUTHOR } from "../consts";
import { formatDate } from "../utils/format";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;
---

<Layout title={title} description={description} ogType="article" publishedDate={date.toISOString()}>
  <article class={styles.article}>
    <header class={styles.header}>
      <h1 class={postTitle}>{title}</h1>
      <div class={metadata}>
        <span>{AUTHOR}</span>
        <span> · </span>
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {tags.length > 0 && (
          <span> · {tags.join(", ")}</span>
        )}
      </div>
    </header>
    <div class={prose}><slot /></div>
    <footer class={styles.footer}><a class={styles.backLink} href="/">← Back to home</a></footer>
  </article>
</Layout>
