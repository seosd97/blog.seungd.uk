---
import { Icon } from "astro-icon/components";
import { iconMoon, iconSun, themeToggleBtn } from "./ThemeToggle.css";
---

<theme-toggle>
  <button class={themeToggleBtn} type="button" aria-label="Toggle theme">
    <Icon name="lucide:sun" class={iconSun} size={18} />
    <Icon name="lucide:moon" class={iconMoon} size={18} />
  </button>
</theme-toggle>

<script>
import { STORAGE_KEYS } from "../constants";

class ThemeToggle extends HTMLElement {
  connectedCallback() {
    this.querySelector("button")?.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      localStorage.setItem(STORAGE_KEYS.theme, next);
    });
  }
}

customElements.define("theme-toggle", ThemeToggle);
</script>
