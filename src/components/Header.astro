---
import ThemeToggle from "./ThemeToggle.astro";
import { header, logo, nav, navLink, navLinkActive, rightGroup } from "./Header.css";
import { SITE_NAME } from "../consts";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<header class={header}>
  <a href="/" class={logo}>{SITE_NAME}</a>
  <div class={rightGroup}>
    <nav class={nav} aria-label="Primary">
      <a href="/" class:list={[navLink, isActive("/") && navLinkActive]}>Articles</a>
      <a href="/archive" class:list={[navLink, isActive("/archive") && navLinkActive]}>Archive</a>
      <a href="/about" class:list={[navLink, isActive("/about") && navLinkActive]}>About</a>
    </nav>
    <ThemeToggle />
  </div>
</header>
