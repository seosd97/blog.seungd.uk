---
import { menuBtn, menuLine } from "./Header.css";

const lineCount = 5;
const gap = 8;
const tops = Array.from({ length: lineCount }, (_, i) => i * (gap + 1));
---

<button
  class={menuBtn}
  type="button"
  aria-label="Open menu"
  aria-expanded="false"
  data-menu-trigger
>
  {tops.map((top) => <span class={menuLine} style={`top:${top}px;`} />)}
</button>
