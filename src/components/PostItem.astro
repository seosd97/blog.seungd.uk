---
import * as styles from "../styles/post-item.css";

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;

const formattedDate = [
  date.getFullYear(),
  String(date.getMonth() + 1).padStart(2, "0"),
  String(date.getDate()).padStart(2, "0"),
].join(".");

const charCount = description.length;
const wordsEstimate = charCount / 3.5;
const readingMinutes = Math.max(1, Math.ceil(wordsEstimate / 200));
---

<article class={styles.item}>
  <a href={`/posts/${slug}`} class={styles.titleLink}> {title} </a>

  <div class={styles.meta}>
    <time datetime={date.toISOString().slice(0, 10)}>{formattedDate}</time>
    <span class={styles.separator} />
    <span>{readingMinutes}min read</span>
    {tags.length > 0 && (
      <>
        <span class={styles.separator} />
        <span class={styles.tagList}>
          {tags.map((t) => (
            <span key={t} class={styles.tag}>{t}</span>
          ))}
        </span>
      </>
    )}
  </div>

  <p class={styles.description}>{description}</p>

  <a href={`/posts/${slug}`} class={styles.readMore}> Read more &rarr; </a>
</article>
