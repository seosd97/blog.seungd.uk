---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import MenuLines from "../components/MenuLines.astro";
import ArticleList from "../components/ArticleList";
import { pageWrapperWide, pageHeading } from "../styles/page.css";
import { SITE_TITLE } from "../consts";

const articles = (await getCollection("articles"))
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const serialized = articles.map((article) => {
  const charCount = article.data.description.length;
  const words = Math.ceil(charCount / 3.5);
  return {
    title: article.data.title,
    description: article.data.description,
    date: article.data.date.toISOString().slice(0, 10),
    tags: article.data.tags,
    slug: article.id,
    readingTime: Math.max(1, Math.ceil(words / 200)),
  };
});
---

<Layout title={SITE_TITLE}>
  <div class={pageWrapperWide}>
    <h1 class={pageHeading}>Articles</h1>
    <MenuLines />
    <ArticleList client:load articles={serialized} />
  </div>
</Layout>
