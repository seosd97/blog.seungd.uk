---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PostList from "../components/PostList";
import * as styles from "../styles/home.css";
import { SITE_TITLE } from "../consts";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const serialized = posts.map((post) => {
  const charCount = post.data.description.length;
  const words = Math.ceil(charCount / 3.5);
  return {
    title: post.data.title,
    description: post.data.description,
    date: post.data.date.toISOString().slice(0, 10),
    tags: post.data.tags,
    slug: post.id,
    readingTime: Math.max(1, Math.ceil(words / 200)),
  };
});
---

<Layout title={SITE_TITLE}>
  <div class={styles.wrapper}>
    <PostList client:load posts={serialized} allTags={allTags} />
  </div>
</Layout>
