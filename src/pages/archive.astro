---
import { format } from "date-fns";
import MenuLines from "../components/MenuLines.astro";
import { APP_METADATA } from "../constants";
import Layout from "../layouts/Layout.astro";
import * as archive from "../styles/archive.css";
import { pageTitle, pageTitleLink, pageWrapper } from "../styles/page.css";
import { getPublishedArticles } from "../utils/articles";

const articles = await getPublishedArticles();

const articlesByYear = articles.reduce<Record<number, typeof articles>>((acc, article) => {
  const year = article.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(article);
  return acc;
}, {});

const years = Object.keys(articlesByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout title={`Archive — ${APP_METADATA.title}`}>
  <div class={pageWrapper}>
    <h1 class={pageTitle}><a href="/archive" class={pageTitleLink}>Archive</a></h1>
    <MenuLines />

    {years.map((year) => (
      <section class={archive.yearSection}>
        <h2 class={archive.yearHeading}>{year}</h2>
        <ul class={archive.articleList}>
          {articlesByYear[year].map((article) => (
            <li class={archive.articleItem}>
              <time class={archive.articleDate}>{format(article.data.date, "MM.dd")}</time>
              <a class={archive.articleLink} href={`/a/${article.id}`}>
                {article.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>
