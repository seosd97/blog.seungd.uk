---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import MenuLines from "../components/MenuLines.astro";
import { pageWrapper, pageTitle } from "../styles/page.css";
import * as archive from "../styles/archive.css";
import { SITE_TITLE } from "../consts";

const articles = (await getCollection("articles"))
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const articlesByYear = articles.reduce<Record<number, typeof articles>>((acc, article) => {
  const year = article.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(article);
  return acc;
}, {});

const years = Object.keys(articlesByYear)
  .map(Number)
  .sort((a, b) => b - a);

const formatDate = (date: Date) => {
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");
  return `${month}.${day}`;
};
---

<Layout title={`Archive — ${SITE_TITLE}`}>
  <div class={pageWrapper}>
    <h1 class={pageTitle}>Archive</h1>
    <MenuLines />

    {years.map((year) => (
      <section key={year} class={archive.yearSection}>
        <h2 class={archive.yearHeading}>{year}</h2>
        <ul class={archive.articleList}>
          {articlesByYear[year].map((article) => (
            <li key={article.id} class={archive.articleItem}>
              <time class={archive.articleDate}>{formatDate(article.data.date)}</time>
              <a class={archive.articleLink} href={`/articles/${article.id}`}>
                {article.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>
